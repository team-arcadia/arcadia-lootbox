# ══════════════════════════════════════════════════════
#  Arcadia LootBox — .gitignore
# ══════════════════════════════════════════════════════

# ── Gradle ───────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ── IDE ──────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.launch
.classpath
.project
.settings/
out/
bin/

# ── NeoForge / Minecraft ────────────────────────────
run/
runs/
logs/
crash-reports/
*.log
debug-*.log.gz

# ── Dependencies (local jars) ───────────────────────
# libs/ is committed so GitHub Actions can compile against arcadia-lib

# ── Java ─────────────────────────────────────────────
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
!libs/*.jar

# ── OS files ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Claude Code ──────────────────────────────────────
.claude/
CLAUDE.md

# ── Misc ─────────────────────────────────────────────
cleanup_repo.bat
*.bak
*.tmp
